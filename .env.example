# ─── Oread Studio environment ───────────────────────────────
# Copy to .env and fill in. Never commit .env.

# Database (remote Postgres). Required unless OREAD_STORAGE=local.
DATABASE_URL=postgres://user:pass@host:5432/oread
# Some managed Postgres (Render) require SSL. Set to "require" to enable.
PGSSLMODE=require

# ─── Storage backend selection ──────────────────────────────
# Default is "postgres". Set to "local" to run worlds from ./data/worlds/*.json
# (single-user / offline). Auth + sessions still use Postgres unless you also
# run in a fully local auth mode (not yet — Postgres auth is required for now).
OREAD_STORAGE=postgres

# ─── Master key for envelope encryption ─────────────────────
# 32-byte key, base64-encoded. Generate: openssl rand -base64 32
# The version suffix supports rotation without bulk re-encryption.
MASTER_KEY_V1=
# The version number new credentials are wrapped with. Bump when adding V2, etc.
MASTER_KEY_ACTIVE_VER=1

# ─── Sessions ───────────────────────────────────────────────
# Secret used to sign/verify the session cookie. openssl rand -base64 48
SESSION_SECRET=
# Session lifetime in days.
SESSION_TTL_DAYS=30
# Set to "true" in production (HTTPS) so cookies are Secure.
COOKIE_SECURE=false
# Comma-separated allow-list of emails permitted to sign up. Leave empty/unset
# to leave signup open to anyone. Compared case-insensitively.
# e.g. SIGNUP_WHITELIST=alice@example.com,bob@example.com
SIGNUP_WHITELIST=

# ─── Server ─────────────────────────────────────────────────
PORT=8080
# Comma-separated allowed origins for the web app (CORS).
WEB_ORIGIN=http://localhost:5173

# ─── AI provider default keys (optional) ────────────────────
# Real provider calls resolve credentials from the encrypted per-user
# credentials table. These env keys are only a fallback for local/dev.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Cloudflare Workers AI
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# AWS Bedrock (uses standard AWS credential chain if unset)
AWS_REGION=us-east-1
# Local (Ollama) base URL
OLLAMA_BASE_URL=http://localhost:11434

# Cheap model used for the chat-distillation pass.
DISTILL_MODEL=claude-haiku-4-5-20251001
